;   go to https://github.com/polybar/polybar
;   https://github.com/lokesh-krishna/dotfiles/blob/master/nord-v2/config/polybar/config

[colors]
nord0 = #2E3440
nord1 = #3B4252
nord2 = #434C5E
nord3 = #4C566A
nord4 = #D8DEE9
nord5 = #E5E9F0
nord6 = #ECEFF4
nord7 = #8FBCBB
nord8 = #88C0D0
nord9 = #81A1C1
nord10 = #5E81AC
nord11 = #BF616A
nord12 = #D08770
nord13 = #EBCB8B
nord14 = #A3BE8C
nord15 = #B48EAD
nord1-trans = #D93B4252

[settings]
screenchange-reload = true
screenchange = true
throttle-output = 5
throttle-output-for = 10
throttle-input-for = 30
compositing-background = source
compositing-foreground = over
compositing-overline = over
compositing-underline = over
compositing-border = over
pseudo-transparency = true

[global/wm]                                                                                    
margin-top = 0                                                                                 
margin-bottom = 0 

[bar/bpar]
width = 100%
height = 24
line-size = 3
offset-y = 0
offset-x = 0
bottom = false
radius = 0
fixed-center = true
wm-restack = bspwm
override-redirect = false
scroll-up = bspwm-desknext
scroll-down = bspwm-deskprev
enable-ipc = true
font-0 = Hack Nerd Font:pixelsize=13:antialias=true;3
font-1 = Hack Nerd Font:pixelsize=13:antialias=true;3
modules-left = bspwm RightArrow1 mod RightArrow2 title
modules-center = 
modules-right = xkeyboard wlan wired pulseaudio battery date time
module-margin-left = 0
module-margin-right = 0
padding-left = 0
padding-right = 0
cursor-click = pointer
cursor-scroll = ns-resize
monitor =
monitor-fallback = eDP-1-1
tray-padding = 10
tray-position = center
tray-maxsize = 15
tray-scale = 1.0
tray-offset-x = 0
tray-offset-y = 0
background = ${colors.nord1-trans}

[module/title]
type = internal/xwindow
format = <label>
format-foreground = ${colors.nord5}
format-background = ${colors.nord1}
format-padding = 1
label = %title%
label-maxlen = 40

[module/RightArrow1]
type = custom/text
content = ""
content-foreground = ${colors.nord8}
content-background = ${colors.nord7}

[module/RightArrow2]
type = custom/text
content = ""
content-foreground = ${colors.nord7}
content-background = ${colors.nord1}

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC
full-at = 99
format-charging = <animation-charging> <label-charging>
format-charging-foreground = ${colors.nord0}
format-charging-background = ${colors.nord14}
format-full = <ramp-capacity> <label-full>
format-full-foreground = ${colors.nord0}
format-full-background = ${colors.nord14}
format-discharging = <ramp-capacity> <label-discharging>
format-discharging-foreground = ${colors.nord0}
format-discharging-background = ${colors.nord14}
label-charging = "%percentage%%"
label-discharging ="%percentage%%"
label-discharging-foreground = ${colors.nord0}
label-full = "%percentage%%"
ramp-capacity-0 = ""
ramp-capacity-1 = ""
ramp-capacity-2 = ""
ramp-capacity-3 = ""
ramp-capacity-4 = ""
ramp-capacity-5 = ""
ramp-capacity-6 = ""
ramp-capacity-7 = ""
ramp-capacity-8 = ""
ramp-capacity-9 = ""
ramp-capacity-framerate = 500
animation-charging-0 = ""
animation-charging-1 = ""
animation-charging-2 = ""
animation-charging-3 = ""
animation-charging-4 = ""
animation-charging-5 = ""
animation-charging-6 = ""
animation-charging-7 = ""
animation-charging-8 = ""
animation-charging-9 = ""
animation-charging-framerate = 500
format-padding = 1
format-charging-padding = 1
format-discharging-padding = 1
format-full-padding = 1

[module/bspwm]
type = internal/bspwm
format = <label-state>
label-focused-occupied = 
label-focused-occupied-foreground = ${colors.nord6}
label-focused-occupied-background = ${colors.nord8}
label-focused-occupied-padding = 1
label-focused-urgent = 
label-focused-urgent-foreground = ${colors.nord11}
label-focused-urgent-background = ${colors.nord8}
label-focused-urgent-padding = 1
label-focused-empty = 
label-focused-empty-foreground = ${colors.nord6}
label-focused-empty-background = ${colors.nord8}
label-focused-empty-padding = 1
label-occupied = 
label-occupied-foreground = ${colors.nord1}
label-occupied-background = ${colors.nord8}
label-occupied-padding = 1
label-urgent = 
label-urgent-foreground = ${colors.nord13}
label-urgent-background = ${colors.nord8}
label-urgent-padding = 1
label-empty = 
label-empty-foreground = ${colors.nord1}
label-empty-background = ${colors.nord8}
label-empty-padding = 1
enable-click = true
enable-scroll = true
reverse-scroll = true
pin-workspaces = false

[module/mod]
type = internal/bspwm
format = <label-mode>
label-monocle = " Monocle "
label-monocle-foreground = ${colors.nord2}
label-monocle-background = ${colors.nord7}
label-tiled = " Tiled "
label-tiled-foreground = ${colors.nord2}
label-tiled-background = ${colors.nord7}
label-fullscreen = " Fullscreen "
label-fullscreen-foreground = ${colors.nord2}
label-fullscreen-background = ${colors.nord7}
label-floating = " Floating "
label-floating-foreground = ${colors.nord2}
label-floating-background = ${colors.nord7}
label-pseudotiled = " Pseudo-Tiled "
label-pseudotiled-foreground = ${colors.nord2}
label-pseudotiled-background = ${colors.nord7}
label-locked = " Locked "
label-locked-foreground = ${colors.nord2}
label-locked-background = ${colors.nord7}
label-sticky = "Sticky "
label-sticky-foreground = ${colors.nord2}
label-sticky-background = ${colors.nord7}
label-private =  "Private "
label-private-foreground = ${colors.nord2}
label-private-background = ${colors.nord7}
format-foreground = ${colors.nord5}
format-background = ${colors.nord1}

[module/mpd]
type = internal/mpd
interval = 1
;host = 127.0.0.1
;port = 6600
;password = 12345
format-online =  <icon-prev><toggle><icon-next><label-time><icon-stop>
format-stopped = <icon-prev><toggle><icon-next>
label-song = %title:0:17:...%
;label-song-background = ${colors.bg-alt}
label-song-foreground = ${colors.fg}
label-song-padding = 1
label-time = %elapsed%/%total%
;label-time-background = ${colors.bg-alt}
label-time-foreground = ${colors.blue}
label-time-padding = 1
icon-play = %{T1}契%{T-}
icon-play-foreground = ${colors.green}
icon-play-padding = 1
icon-pause = %{T1}%{T-}
icon-pause-foreground = ${colors.green}
icon-pause-padding = 1
icon-stop = %{T1}栗%{T-}
icon-stop-foreground = ${colors.red}
icon-stop-padding = 1
icon-prev = %{T1}玲%{T-}
icon-prev-foreground = ${colors.cyan}
icon-prev-padding = 1
icon-next = %{T1}怜%{T-}
icon-next-foreground = ${colors.cyan}
icon-next-padding = 1

[module/pulseaudio]
type = internal/pulseaudio
format-volume = %{A3:pavucontrol &:}<ramp-volume> <label-volume>%{A}
format-volume-padding = 1
use-ui-max = false 
label-volume = %percentage%%
label-muted = 婢 Mute
ramp-volume-0 = 奄 
ramp-volume-1 = 奔
ramp-volume-2 = 墳
label-volume-padding = 0
format-muted-padding = 1
format-volume-foreground = ${colors.nord0}
format-volume-background = ${colors.nord13}
format-muted-foreground = ${colors.nord0}
format-muted-background = ${colors.nord13}

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock
blacklist-1 = caps lock
format = <label-layout>
format-spacing = 0
label-layout =   %layout%
label-layout-padding = 1
label-indicator-padding = 0
label-indicator-margin = 0
label-layout-foreground =  ${colors.nord0}
label-layout-background =  ${colors.nord8}

[module/date]
type = internal/date
interval = 60
date = %a %d
label = "  %date% "
format = %{A3:gsimplecal &:}<label>%{A}
format-foreground = ${colors.nord0}
format-background = ${colors.nord10}
format-padding = 1

[module/time]
type = internal/date
time = %H:%M
label = " %time%"
format-foreground = ${colors.nord0}
format-background = ${colors.nord15}
format-padding = 1

[module/wired]
type = internal/network
interface = enp2s0
interval = 1.0
format-connected = <label-connected>
format-connected-padding = 1
label-connected =  %downspeed%
format-disconnected = <label-disconnected>
label-disconnected =
format-connected-foreground = ${colors.nord0}
format-connected-background = ${colors.nord12}
format-disconnected-foreground = ${colors.nord0}
format-disconnected-background = ${colors.nord12}

[module/wlan]
type = internal/network
interface = wlp3s0
interval = 1.0
format-connected = <label-connected>
format-connected-padding = 1
label-connected = ﬉ %essid%
format-disconnected = <label-disconnected>
label-disconnected =
format-connected-foreground = ${colors.nord0}
format-connected-background = ${colors.nord12}
format-disconnected-foreground = ${colors.nord0}
format-disconnected-background = ${colors.nord12}

; vim:ft=dosini
